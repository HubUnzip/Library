local function New(Class, Props)
    local Obj = Instance.new(Class)
    for i,v in pairs(Props or {}) do
        Obj[i] = v
    end
    return Obj
end

local function Corner(Obj, Radius)
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, Radius or 6)
    UICorner.Parent = Obj
    return UICorner
end

local function Stroke(Obj, Color, Thickness, Transparency)
    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = Color or Color3.fromRGB(60,60,60)
    UIStroke.Thickness = Thickness or 1
    UIStroke.Transparency = Transparency or 0
    UIStroke.Parent = Obj
    return UIStroke
end

local function Padding(Obj, L, R, T, B)
    local UIPadding = Instance.new("UIPadding")
    UIPadding.PaddingLeft = UDim.new(0, L or 0)
    UIPadding.PaddingRight = UDim.new(0, R or 0)
    UIPadding.PaddingTop = UDim.new(0, T or 0)
    UIPadding.PaddingBottom = UDim.new(0, B or 0)
    UIPadding.Parent = Obj
    return UIPadding
end

local function Dragify(Drag, Main)
    local dragging = false
    local dragStart
    local startPos

    Drag.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function SafeParent()
    local Success, Result = pcall(function()
        return gethui and gethui() or CoreGui
    end)

    if Success and Result then
        return Result
    end

    return CoreGui
end

function Library:Notify(Title, Text, Duration)
    if not self._NotifyHolder or not self._NotifyHolder.Parent then
        return
    end

    Duration = Duration or 3

    local Holder = New("Frame", {
        Size = UDim2.new(0, 280, 0, 0),
        BackgroundColor3 = Color3.fromRGB(19,19,19),
        BorderSizePixel = 0,
        Parent = self._NotifyHolder
    })
    Corner(Holder, 8)
    Stroke(Holder, Color3.fromRGB(55,55,55), 1, 0)

    local Top = New("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        BackgroundColor3 = Color3.fromRGB(0, 170, 255),
        BorderSizePixel = 0,
        Parent = Holder
    })
    Corner(Top, 8)

    local TitleLabel = New("TextLabel", {
        Size = UDim2.new(1, -12, 0, 18),
        Position = UDim2.new(0, 8, 0, 6),
        BackgroundTransparency = 1,
        Text = tostring(Title or "Notification"),
        Font = Enum.Font.Code,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextColor3 = Color3.fromRGB(255,255,255),
        Parent = Holder
    })

    local TextLabel = New("TextLabel", {
        Size = UDim2.new(1, -12, 0, 30),
        Position = UDim2.new(0, 8, 0, 24),
        BackgroundTransparency = 1,
        TextWrapped = true,
        TextYAlignment = Enum.TextYAlignment.Top,
        Text = tostring(Text or ""),
        Font = Enum.Font.Code,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextColor3 = Color3.fromRGB(170,170,170),
        Parent = Holder
    })

    Holder.Size = UDim2.new(0, 280, 0, 58)
    Holder.BackgroundTransparency = 1
    TitleLabel.TextTransparency = 1
    TextLabel.TextTransparency = 1
    Top.BackgroundTransparency = 1

    TweenService:Create(Holder, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
    TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
    TweenService:Create(TextLabel, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
    TweenService:Create(Top, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()

    task.delay(Duration, function()
        if Holder then
            TweenService:Create(Holder, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
            TweenService:Create(TextLabel, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
            TweenService:Create(Top, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            task.wait(0.22)
            Holder:Destroy()
        end
    end)
end

