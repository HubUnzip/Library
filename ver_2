                            Holder.Size = UDim2.new(1, 0, 0, 24)
                            if Callback then
                                Callback(Selected)
                            end
                        end)
                    end
                end

                MainButton.MouseButton1Click:Connect(function()
                    Open = not Open
                    Rebuild()
                    if Open then
                        Holder.Size = UDim2.new(1, 0, 0, 26 + (#List * 22))
                    else
                        Holder.Size = UDim2.new(1, 0, 0, 24)
                    end
                end)

                return {
                    Set = function(_, v)
                        Selected = v
                        ValueLabel.Text = tostring(v)
                        if Callback then
                            Callback(v)
                        end
                    end,
                    Refresh = function(_, NewList)
                        List = NewList or {}
                        Rebuild()
                    end,
                    Get = function()
                        return Selected
                    end
                }
            end

            return SectionApi
        end

        table.insert(Window.Tabs, {
            Button = TabButton,
            Page = Page
        })

        if #Window.Tabs == 1 then
            SelectTab()
        end

        return Tab
    end

    return Window
end

return Library
